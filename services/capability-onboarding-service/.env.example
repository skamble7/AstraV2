SERVICE_NAME=capability-onboarding-service
CAPABILITY_SVC_BASE_URL=http://localhost:9021
ARTIFACT_SVC_BASE_URL=http://localhost:9020
HTTP_CLIENT_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# LLM config for capability metadata inference (ConfigForge pattern)
CONFIG_FORGE_URL=http://localhost:8040
ONBOARDING_LLM_CONFIG_REF=dev.llm.openai.fast

# When running inside Docker, set this to 'host.docker.internal' so that
# 'localhost' in user-supplied MCP URLs resolves to the Docker host.
# Leave blank when running the service directly on the host machine.
MCP_LOCALHOST_ALIAS=

# RELOAD=1 enables uvicorn hot-reload (development only)
RELOAD=0
