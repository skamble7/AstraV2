# ──────────────────────────────
# MongoDB (shared with monorepo)
# ──────────────────────────────
#MONGO_URI=mongodb://host.docker.internal:27017/
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=astra

# ──────────────────────────────
# Service basics
# ──────────────────────────────
SERVICE_NAME=astraui-resolver-service
APP_PORT=9024
LOG_LEVEL=INFO

# CORS (comma-separated; use * for dev)
CORS_ALLOW_ORIGINS=*