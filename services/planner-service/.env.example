# MongoDB
MONGO_URI=mongodb://host.docker.internal:27017/
MONGO_DB=astra

# Redis
REDIS_URL=redis://host.docker.internal:6379/0

# RabbitMQ
RABBITMQ_URI=amqp://raina:raina@host.docker.internal:5672/
RABBITMQ_EXCHANGE=raina.events
EVENTS_ORG=astra

# Downstream services
CAPABILITY_SVC_BASE_URL=http://host.docker.internal:9021
CONDUCTOR_SVC_BASE_URL=http://host.docker.internal:9022
ARTIFACT_SVC_BASE_URL=http://host.docker.internal:9020

# Service
SERVICE_NAME=planner-service
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# LLM (ConfigForge ref for planner agent LLM)
CONFIG_FORGE_URL=http://host.docker.internal:8040
#PLANNER_LLM_CONFIG_REF=dev.llm.openai.fast
#PLANNER_LLM_CONFIG_REF=dev.llm.google_genai.flash
PLANNER_LLM_CONFIG_REF=dev.llm.bedrock.explicit-creds


# Diagram MCP server (platform enrichment — always available independently of capability registry)
DIAGRAM_MCP_BASE_URL=http://host.docker.internal:8001
DIAGRAM_MCP_PATH=/mcp
DIAGRAM_MCP_TIMEOUT_SEC=120

# Cache
MANIFEST_CACHE_TTL_SECONDS=300

# Consumer queues
CONSUMER_QUEUE_CAPABILITY=planner.capability.v1

# Skip enrichment nodes (saves time and cost during testing)
SKIP_DIAGRAM=1
SKIP_NARRATION=1
