# ──────────────────────────────
# MongoDB Atlas (replace creds)
# ──────────────────────────────
#MONGO_URI=mongodb://host.docker.internal:27017/
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=astra

# ──────────────────────────────
# RabbitMQ (shared)
# ──────────────────────────────
# Default points to host broker (Docker Desktop: host.docker.internal)
RABBITMQ_URI=amqp://raina:raina@host.docker.internal:5672/
# Canonical exchange used by astra
RABBITMQ_EXCHANGE=raina.events

# ──────────────────────────────
# Event org segments
# ──────────────────────────────
EVENTS_ORG=astra
PLATFORM_EVENTS_ORG=platform

# ──────────────────────────────
# Service identity
# ──────────────────────────────
SERVICE_NAME=capability-service

# Seeds toggles
SEED_INTEGRATIONS=1
SEED_CAPABILITIES=1
SEED_PACKS=1
PACK_SEED_PUBLISH=1

# Demo endpoints for MCP servers (override as needed)
COBOL_PARSER_ENDPOINT=http://host.docker.internal:7101
JCL_PARSER_ENDPOINT=http://host.docker.internal:7102
CALLGRAPH_ENDPOINT=http://host.docker.internal:7103
