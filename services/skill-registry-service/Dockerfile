FROM public.ecr.aws/docker/library/python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# 1) Install shared libs (editable) — copy project root + package dir
COPY libs/pyproject.toml /tmp/libs/pyproject.toml
COPY libs /tmp/libs/libs
RUN pip install --no-cache-dir -e /tmp/libs

# 2) Install astra-models (shared domain models — includes skill_models)
COPY libs/astra-models /tmp/astra-models
RUN pip install --no-cache-dir /tmp/astra-models

# 3) Install service deps (from service pyproject)
COPY services/skill-registry-service/pyproject.toml /app/pyproject.toml
RUN pip install --no-cache-dir .

# 4) Copy the service code
COPY services/skill-registry-service/app /app/app

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "9028"]
