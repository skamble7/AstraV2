# ──────────────────────────────
# MongoDB
# ──────────────────────────────
#MONGO_URI=mongodb://host.docker.internal:27017/
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=astra

# ──────────────────────────────
# RabbitMQ (shared)
# ──────────────────────────────
RABBITMQ_URI=amqp://raina:raina@host.docker.internal:5672/
RABBITMQ_EXCHANGE=raina.events

# ──────────────────────────────
# Event org segments
# ──────────────────────────────
EVENTS_ORG=astra
PLATFORM_EVENTS_ORG=platform

# ──────────────────────────────
# Downstream service endpoints
# ──────────────────────────────
CAPABILITY_SVC_BASE_URL=http://host.docker.internal:9021
ARTIFACT_SVC_BASE_URL=http://host.docker.internal:9020

# ──────────────────────────────
# HTTP client
# ──────────────────────────────
HTTP_CLIENT_TIMEOUT_SECONDS=30

# ──────────────────────────────
# Service identity / logging
# ──────────────────────────────
SERVICE_NAME=conductor-service
LOG_LEVEL=INFO

# ──────────────────────────────
# ConfigForge — LLM configuration
# ──────────────────────────────
# URL of the ConfigForge service
CONFIG_FORGE_URL=http://host.docker.internal:8040

# ConfigForge canonical ref for the conductor's agent LLM.
# Also used as the fallback when OVERRIDE_CAPABILITY_LLM=1.
#CONDUCTOR_LLM_CONFIG_REF=dev.llm.openai.fast
#CONDUCTOR_LLM_CONFIG_REF=dev.llm.google_genai.flash
CONDUCTOR_LLM_CONFIG_REF=dev.llm.bedrock.explicit-creds

# When set to 1, ALL capabilities use CONDUCTOR_LLM_CONFIG_REF instead of their own llm_config_ref.
# Useful for testing, cost control, or forcing a single provider.
OVERRIDE_CAPABILITY_LLM=1

# ──────────────────────────────
# Enrichment skip flags
# ──────────────────────────────
# Set to 1 to skip diagram/narrative enrichment nodes during runs (saves time and cost in testing).
SKIP_DIAGRAM=1
SKIP_NARRATION=1